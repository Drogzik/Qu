  <Target Name="CopyLlamaDllsFromDebugToRelease" AfterTargets="CopyShellUi" Condition="'$(Configuration)|$(Platform)'=='Release|x64'">
    <ItemGroup>
      <_DebugDlls Include="$(ProjectDir)x64\Debug\*.dll" />
    </ItemGroup>
    <Copy SourceFiles="@(_DebugDlls)" DestinationFolder="$(OutDir)" SkipUnchangedFiles="true" />
  </Target>
  <Target Name="CopyShellUi" AfterTargets="Build">
    <ItemGroup>
      <UiShellFiles Include="$(ProjectDir)ui\**\*.*" />
    </ItemGroup>
    <Copy SourceFiles="@(UiShellFiles)"
          DestinationFiles="@(UiShellFiles->'$(OutDir)ui\%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true" />
    <MakeDir Directories="$(OutDir)models" Condition="Exists('$(ProjectDir)models\readme.txt')" />
    <Copy SourceFiles="$(ProjectDir)models\readme.txt"
          DestinationFolder="$(OutDir)models"
          SkipUnchangedFiles="true"
          Condition="Exists('$(ProjectDir)models\readme.txt')" />
    <Copy SourceFiles="$(MSBuildProjectDirectory)\..\..\Installer\download_model.ps1"
          DestinationFolder="$(OutDir)"
          SkipUnchangedFiles="true"
          Condition="Exists('$(MSBuildProjectDirectory)\..\..\Installer\download_model.ps1')" />
  </Target>
  <!-- После Release | x64 + ui: Inno Setup 6 → ..\..\Installer\Output\PomoshnikSetup.exe -->
  <Target Name="BuildInnoInstaller"
          AfterTargets="CopyLlamaDllsFromDebugToRelease"
          Condition="'$(Configuration)|$(Platform)'=='Release|x64' And '$(SkipInnoInstaller)'!='true'">
    <PropertyGroup>
      <_InstallerDir>$(MSBuildProjectDirectory)\..\..\Installer</_InstallerDir>
      <_BinDirRaw>$([System.IO.Path]::GetFullPath('$(TargetDir)'))</_BinDirRaw>
    </PropertyGroup>
    <PropertyGroup>
      <_BinDir>$([System.String]::Copy('$(_BinDirRaw)').TrimEnd('\'))</_BinDir>
      <_UiDir>$([System.IO.Path]::GetFullPath('$(ProjectDir)ui'))</_UiDir>
    </PropertyGroup>
    <PropertyGroup>
      <InnoCompiler Condition="Exists('$(LOCALAPPDATA)\Programs\Inno Setup 6\ISCC.exe')">$(LOCALAPPDATA)\Programs\Inno Setup 6\ISCC.exe</InnoCompiler>
    </PropertyGroup>
    <PropertyGroup>
      <InnoCompiler Condition="'$(InnoCompiler)' == '' And Exists('$(ProgramW6432)\Inno Setup 6\ISCC.exe')">$(ProgramW6432)\Inno Setup 6\ISCC.exe</InnoCompiler>
    </PropertyGroup>
    <PropertyGroup>
      <InnoCompiler Condition="'$(InnoCompiler)' == '' And Exists('$(ProgramFiles(x86))\Inno Setup 6\ISCC.exe')">$(ProgramFiles(x86))\Inno Setup 6\ISCC.exe</InnoCompiler>
    </PropertyGroup>
    <Warning Text="Inno Setup 6 не найден — установщик не собран. Установи с https://jrsoftware.org/isdl.php и снова собери Release | x64."
             Condition="'$(InnoCompiler)' == ''" />
    <MakeDir Directories="$(_InstallerDir)\Output" Condition="'$(InnoCompiler)' != ''" />
    <!-- Cursor/VS часто сохраняют .iss как UTF-16; Inno требует UTF-8 (иначе Illegal null character). -->
    <Exec Condition="'$(InnoCompiler)' != ''"
          IgnoreExitCode="false"
          Command="powershell -NoProfile -ExecutionPolicy Bypass -Command &quot;$p = [System.IO.Path]::Combine('$(_InstallerDir)', 'Pomoshnik.iss'); $t = [System.IO.File]::ReadAllText($p); [System.IO.File]::WriteAllText($p, $t, (New-Object System.Text.UTF8Encoding $false))&quot;" />
    <Exec WorkingDirectory="$(_InstallerDir)"
          Command="&quot;$(InnoCompiler)&quot; /DBuildDir=&quot;$(_BinDir)&quot; /DUiDir=&quot;$(_UiDir)&quot; &quot;$(_InstallerDir)\Pomoshnik.iss&quot;"
          Condition="'$(InnoCompiler)' != ''" />
    <Message Importance="high"
             Text="Установщик: Installer\Output\PomoshnikSetup.exe"
             Condition="'$(InnoCompiler)' != ''" />
  </Target>
