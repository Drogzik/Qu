  <Target Name="CopyShellUi" AfterTargets="Build">
    <ItemGroup>
      <UiShellFiles Include="$(ProjectDir)ui\**\*.*" />
    </ItemGroup>
    <Copy SourceFiles="@(UiShellFiles)"
          DestinationFiles="@(UiShellFiles->'$(OutDir)ui\%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true" />
    <Copy SourceFiles="@(UiShellFiles)"
          DestinationFiles="@(UiShellFiles->'$(ProjectDir)..\..\run\ui\%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true"
          Condition="Exists('$(ProjectDir)..\..\run')" />
  </Target>
  <Target Name="CopyBuiltExeToRun" AfterTargets="Build" Condition="Exists('$(ProjectDir)..\..\run')">
    <!-- If Pomoshnik.exe is running, the file is locked and Copy fails (MSB3026/MSB3027). -->
    <Exec Command="taskkill /F /IM Pomoshnik.exe /T &gt;nul 2&gt;&amp;1" IgnoreExitCode="true" />
    <!-- If you run from VS debugger, the original exe name can be locked too. -->
    <Exec Command="taskkill /F /IM ConsoleApplication1.exe /T &gt;nul 2&gt;&amp;1" IgnoreExitCode="true" />
    <!-- Stable approach: MSBuild Copy with retries, but don't fail the whole build if file is still locked. -->
    <Copy SourceFiles="$(TargetPath)"
          DestinationFiles="$(ProjectDir)..\..\run\Pomoshnik.exe"
          SkipUnchangedFiles="true"
          Retries="25"
          RetryDelayMilliseconds="250"
          ContinueOnError="true" />
  </Target>
